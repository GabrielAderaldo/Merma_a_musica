# Frontend SPA (assets estáticos)
merma.caninhagames.fortal.br {
	root * /srv/frontend
	try_files {path} /index.html
	file_server
}

# Backend BEAM (API REST + WebSocket)
merma-api.caninhagames.fortal.br {
	# API routes
	handle /api/* {
		reverse_proxy app:4000
	}

	# Auth callbacks (OAuth)
	handle /auth/* {
		reverse_proxy app:4000
	}

	# Health check
	handle /health {
		reverse_proxy app:4000
	}

	# WebSocket (Phoenix Channels)
	handle /socket/* {
		reverse_proxy app:4000
	}

	# Fallback
	respond "Not Found" 404
}

  "scripts": {
    "dev": "bun ./index.html",
    "build": "bun build ./index.html --minify --outdir=dist",
    "test": "bun test",
    "lint": "bunx oxlint ."
  },
  "dependencies": {
    "phoenix": "^1.7.0"
  },
  "devDependencies": {
    "bun-plugin-tailwind": "^0.1.0",
    "tailwindcss": "^4.0.0",
    "oxlint": "^0.16.0",
    "typescript": "^5.7.0"
  }
}
